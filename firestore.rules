// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (UID)
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (optional)
//   - photoURL: string (optional)
//   - balance: number (required, >= 0)
//   - role: string (required, ['user', 'admin'])
//   - createdAt: string (format: date-time)
//
// Collection: services
// Document ID: serviceId
// Fields:
//   - category: string (required)
//   - name: string (required)
//   - price: number (required, > 0)
//   - min: number (required, > 0)
//   - max: number (required, > min)
//   - description: string (optional)
//   - active: bool (required)
//
// Collection: orders
// Document ID: orderId
// Fields:
//   - userId: string (required, immutable)
//   - serviceId: string (required)
//   - serviceName: string (required)
//   - link: string (required)
//   - quantity: number (required, > 0)
//   - charge: number (required, >= 0)
//   - status: string (required, ['pending', 'processing', 'completed', 'cancelled', 'refunded'])
//   - createdAt: string (required, format: date-time)
//
// Collection: transactions
// Document ID: transactionId
// Fields:
//   - userId: string (required, immutable)
//   - amount: number (required)
//   - type: string (required, ['deposit', 'order', 'refund'])
//   - description: string (optional)
//   - createdAt: string (required, format: date-time)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions (Self-Sustained Mode)
    // ===============================================================

    function isPublic() {
      return true; // Self-sustained mode: no Firebase Auth required
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isPublic();
    }

    match /services/{serviceId} {
      allow read, write: if isPublic();
    }

    match /orders/{orderId} {
      allow read, write: if isPublic();
    }

    match /transactions/{transactionId} {
      allow read, write: if isPublic();
    }

    match /depositRequests/{requestId} {
      allow read, write: if isPublic();
    }
  }
}
