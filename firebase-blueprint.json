{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "balance": { "type": "number", "description": "Current account balance" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "freeDemoClaimed": { "type": "boolean", "description": "Whether the user has claimed the free demo" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "SMM service details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number", "description": "Price per 1000 units" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "description": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["category", "name", "price", "min", "max", "active"]
    },
    "Order": {
      "title": "Order",
      "description": "User service order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "charge": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "link", "quantity", "charge", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "order", "refund"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available SMM services"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "User orders"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    }
  }
}
